# Database Connection Configuration Example
# Copy this file to db.properties and fill in your local settings

db.server=localhost
db.port=1433
db.name=CarRentalDB
db.user=YOUR_DB_USER
db.password=YOUR_DB_PASSWORD
db.encrypt=true
db.trustServerCertificate=true

# OpenRouteService API Key (Sign up for free at https://openrouteservice.org/ or set ORS_API_KEY env var)
ors.api.key=YOUR_OPENROUTESERVICE_API_KEY
